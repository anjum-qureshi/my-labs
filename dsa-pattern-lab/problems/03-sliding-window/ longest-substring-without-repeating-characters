In Go, the slice expression s[i:j] includes index i but excludes index j. 
Therefore, if I want to include the last character of the string in a substring, j must be allowed to reach len(s)
func lengthOfLongestSubstring(s string) int {
    longestLength := 0
    uniqueChars := make(map[rune]struct{})
    for i := 0; i < len(s); i++ {
        for j := i + 1; j <= len(s); j++ {
            substring := s[i:j]
            if isUnique(substring) {
                if len(substring) > longestLength {
                    longestLength = len(substring)
                }
            }
        }
    }
    return longestLength
}


func isUnique(substring string) bool {
    charMap := make(map[rune]struct{})
    for _, char := range substring {
        if _, exists := charMap[char]; exists {
            return false
        }
        charMap[char] = struct{}{}
    }
    return true
}


