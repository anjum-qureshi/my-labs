func lengthOfLongestSubstring(s string) int {
    longestLength := 0
    uniqueChars := make(map[rune]struct{})
    i, j := 0, 0

    for i < len(s) {
        if _, exists := uniqueChars[rune(s[j])]; !exists {
            uniqueChars[rune(s[j])] = struct{}{}
            j++
            length := j - i
            if length > longestLength {
                longestLength = length
            }
        } else {
            // delete(uniqueChars, rune(s[i]))
            i++
        }
        if j == len(s) {
            break
        }
    }

    return longestLength
}


